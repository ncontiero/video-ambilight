{
  "name": "video-ambilight",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.1",
  "description": "🌈 Ambilight Effect - React - Next.js (YouTube iframe, Video).",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "tailwind": "tailwindcss -i ./styles/input.css -o ./dist/output.css",
    "build:next": "pnpm -F='nextjs' build",
    "dev:next": "pnpm -F='nextjs' dev",
    "start:next": "pnpm -F='nextjs' start",
    "build": "pnpm tailwind --minify",
    "dev": "pnpm tailwind --watch",
    "lint": "eslint . && pnpm -F='nextjs' lint",
    "lint:fix": "eslint . --fix && pnpm -F='nextjs' lint:fix"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.2.1",
    "@tailwindcss/cli": "4.3.0",
    "eslint": "10.4.0",
    "tailwindcss": "4.3.0"
  }
}
